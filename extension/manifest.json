{
  "manifest_version": 3,
  "name": "Movie Night Controller",
  "version": "1.0.0",
  "description": "Sync video playback across multiple streaming services for watch parties.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.netflix.com/*"],
      "js": ["providers/netflix-cadmium.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.netflix.com/*"],
      "js": [
        "providers/base-video-provider.js",
        "providers/netflix-provider.js",
        "content/netflix.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.hotstar.com/*",
        "https://www.disneyplus.com/*"
      ],
      "js": [
        "providers/base-video-provider.js",
        "providers/hotstar-provider.js",
        "content/hotstar.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.primevideo.com/*",
        "https://www.amazon.com/gp/video/*",
        "https://www.amazon.in/gp/video/*"
      ],
      "js": [
        "providers/base-video-provider.js",
        "providers/prime-provider.js",
        "content/prime.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
